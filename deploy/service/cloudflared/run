#!/data/data/com.termux/files/usr/bin/bash
set -Eeuo pipefail
BASE="${BASE:-$HOME/services/ufi-web}"
ENV_FILE="${CLOUDFLARED_ENV:-$HOME/.config/ufi-web/cloudflared.env}"
test ! -f "$ENV_FILE" || . "$ENV_FILE"
BIN="${CLOUDFLARED_BIN:-$PREFIX/bin/cloudflared}"
CONFIG="${CLOUDFLARED_CONFIG:-$HOME/.cloudflared/config.yml}"
TUNNEL="${CLOUDFLARED_TUNNEL:-}"
TOKEN="${CLOUDFLARED_TOKEN:-}"
export LANG="${LANG:-zh_CN.UTF-8}" LC_ALL="${LC_ALL:-C.UTF-8}"
test -x "$BIN" || { echo "cloudflared 未找到: $BIN" >&2; exit 1; }
if test -z "$TOKEN"; then
  test -f "$CONFIG" || { echo "Cloudflare 配置不存在: $CONFIG" >&2; exit 1; }
fi
cd "$BASE"
mkdir -p "$BASE/logs"
if test -n "$TOKEN"; then
  exec "$BIN" --config "$CONFIG" tunnel run --token "$TOKEN" >>"$BASE/logs/cloudflared.log" 2>&1
fi
if test -n "$TUNNEL"; then
  exec "$BIN" --config "$CONFIG" tunnel run "$TUNNEL" >>"$BASE/logs/cloudflared.log" 2>&1
fi
exec "$BIN" --config "$CONFIG" tunnel run >>"$BASE/logs/cloudflared.log" 2>&1
